# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=url-shortener
BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/url_shortener?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ─────────────────────────────────────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400
CACHE_SHORT_URL_PREFIX=url:

# ─────────────────────────────────────────────────────────────────────────────
# URL SHORTENER
# ─────────────────────────────────────────────────────────────────────────────
SHORT_CODE_LENGTH=7
MAX_URL_LENGTH=2048
ALLOWED_SCHEMES=http,https

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SHORTEN_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# BULLMQ / ANALYTICS
# ─────────────────────────────────────────────────────────────────────────────
ANALYTICS_QUEUE_NAME=analytics
ANALYTICS_WORKER_CONCURRENCY=5

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
